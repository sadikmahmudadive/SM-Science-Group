rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user is an admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: Check if the user is a teacher
    function isTeacher() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    // Helper: Check if the user is a student
    function isStudent() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student'
      );
    }

    match /admins/{adminId} {
      allow read, write: if true; // TEMPORARY: Lock this down in production
    }

    match /users/{userId} {
      // Admins have full access
      // Users can read/update their own profile
      // Teachers can read student profiles for attendance
      allow read, write: if isAdmin() 
                         || (request.auth != null && request.auth.uid == userId)
                         || (isTeacher() && resource.data.role == 'student')
                         || true; // TEMPORARY: Maintaining existing override
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null &&
                  (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ==========================================
    // DASHBOARD COLLECTIONS
    // ==========================================

    match /classes/{classId} {
      // Anyone logged in can read classes
      allow read: if request.auth != null;
      // Only admins can create/edit classes
      allow write: if isAdmin(); 
    }

    match /assignments/{assignmentId} {
      allow read: if request.auth != null;
      // Admins and Teachers can manage assignments
      allow write: if isAdmin() || isTeacher();
    }

    match /submissions/{submissionId} {
      allow read: if request.auth != null;
      // Students write their own, Teachers/Admins read all
      allow write: if request.auth != null;
    }

    match /attendance/{recordId} {
      // Teachers and Admins can read/write attendance records
      allow read, write: if request.auth != null && (isAdmin() || isTeacher());
    }

    match /teacher_attendance/{recordId} {
      allow read, write: if request.auth != null && (isAdmin() || isTeacher());
    }

    // ==========================================
    // PUBLIC WEBSITE COLLECTIONS
    // ==========================================

    match /publicTeachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
