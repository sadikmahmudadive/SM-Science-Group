rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow read, write: if true; // TEMPORARY: Remember to lock this down later
    }

    match /users/{userId} {
      // Admins have full access
      // Users can read/update their own profile
      // Anyone can read if they are just checking their pre-approved email
      allow read, write: if isAdmin() 
                         || (request.auth != null && request.auth.uid == userId)
                         || (request.auth != null && resource.data.email == request.auth.token.email)
                         || true; // TEMPORARY: Matches your temporary override
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null &&
                  (resource == null || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // ==========================================
    // NEW DASHBOARD COLLECTIONS
    // ==========================================

    match /classes/{classId} {
      // Anyone logged in can read classes (needed for students/teachers to see their classes)
      allow read: if request.auth != null;
      // Only admins can create/edit classes
      allow write: if isAdmin(); 
    }

    match /assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null); // Teachers might need to create these
    }

    match /submissions/{submissionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Students need to write submissions
    }

    // ==========================================
    // PUBLIC WEBSITE COLLECTIONS
    // ==========================================

    match /publicTeachers/{teacherId} {
      // Anyone (even guests) can read public profiles for the homepage
      allow read: if true;
      // Only admins can manage the public profiles
      allow write: if isAdmin();
    }
  }
}
